<h1 class="text-center"><%=@article.title%></h1>
<h6 class="card-subtitle mb-2 text-muted text-center"> <%= @article.user.username %> </h6>


<div class="container">
    <div class="card shadow-sm p-3 mb-5 bg-white rounded mt-5">
      <div class="card-body">
        <%= @article.description %>
      </div>
    </div>
</div>

<div class="container text-center">
    <%= link_to 'Articles', articles_path, class: 'btn btn-primary btn-lg mb-3' %>
</div>
