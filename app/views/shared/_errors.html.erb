<% if @article.errors.any? %>
<div class="container">
		<div class="alert alert-danger" role="alert">
		  <h4 class="alert-heading">The following errors prevented the article from being submited: </h4>
		  <hr>
		  <ul>
		  		<% @article.errors.full_messages.each do |error| %>
					<li><%= error %></li>
				<% end %>
		  </ul>
		</div>
	</div>
<% end %>