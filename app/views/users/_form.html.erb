<%= render 'shared/errors', obj: @user%>
<div class="row justify-content-center mt-5">
	<div class="col-4">
		<%= form_with(model: @user, class: "border  bg-light p-5 shadow-sm p-3 mb-5 bg-white rounded", local: true) do |f| %>
			<div class="container">
			<div class="container text-center mb-2">
			
				<% if params[:action] == 'edit' %>
					<div class="container mb-5">
						<%= gravatar_for @user, size: 200 %>
					</div>
				<% else %>

					<%= show_svg('carbon_user-avatar.svg') %>

					
				<% end %>



			</div>
		    	<div class="form-group row">
					<%= f.label :username, class: "col-2 col-form-label " %>
					<div class="col-10">
						<%= f.text_field :username, class: "form-control shadow-sm p-3 bg-white rounded", placeholder: 'Enter a Username' %>
					</div>
				</div>

		    	<div class="form-group row">
		    	    <%= f.label :email, class: "col-2 col-form-label" %>
		    	    <div class="col-10">
						<%= f.email_field :email, class: "form-control shadow-sm p-3 bg-white rounded", placeholder: 'Enter your email address' %>
					</div>
		    	</div>

				<div class="form-group row">
		    	    <%= f.label :password, class: "col-2 col-form-label" %>
		    	    <div class="col-10">
						<%= f.password_field :password, class: "form-control shadow-sm p-3 bg-white rounded", placeholder: 'Choose your password' %>
					</div>
		    	</div>



				</div>

	
							<% if logged_in? && (@user == current_user || current_user.admin?) %>
								<div class="container text-center d-flex justify-content-between mt-4">
								<%= link_to 'Delete', user_path(@user), method: :delete, data: {confirm: 'Are you sure?'}, class: 'btn btn-danger btn-lg' %>

								<div>
										<%= link_to 'Cancel', user_path(@user), class: "btn btn-outline-secondary btn-lg" %>

										<%= f.submit(@user.new_record? ? "Sign up" : "Update Account", class: "btn btn-primary btn-lg" )%>

								</div>
							<% else %>
							
							<div class="container text-center">
								<%= f.submit(@user.new_record? ? "Sign up" : "Update Account", class: "btn btn-primary btn-lg" )%>
							</div>


							<% end %>

							
							

				


				
	   </div>
<% end %>
</div>



